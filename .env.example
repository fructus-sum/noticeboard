# Optional overrides. Copy to .env and edit as needed.
# All core config (port, password, MAC list) lives in data/config.json.

# Set to 'production' for the running service; leave unset or 'development' for local dev.
NODE_ENV=development

# Override the listening port (default: 3000, also set in data/config.json).
# PORT=3000

# Set to 'true' ONLY if serving over HTTPS (e.g. behind a reverse proxy with TLS).
# Pi installs use plain HTTP on a local network — leave this false.
SECURE_COOKIES=false
